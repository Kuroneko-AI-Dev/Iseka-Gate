{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "baseUrl": ".",

    "paths": {
      "@framework/*": [
        "src/framework/*"
      ],
      "@live2d/*": [
        "src/live2d/*"
      ]
    },

    "strict": false,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,

    "skipLibCheck": true,

    "ignoreDeprecations": "6.0"
  },

  "include": [
    "src"
  ]
}